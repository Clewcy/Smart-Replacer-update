{
  "name": "Smart Code Replacer",
  "short_name": "CodeReplacer",
  "id": "smart-code-replacer-pwa",
  "start_url": "./index.html?homescreen=1",
  "scope": "./",
  "display": "standalone",
  "display_override": ["standalone", "fullscreen", "minimal-ui"],
  "orientation": "any",
  "background_color": "#1e1e1e",
  "theme_color": "#2d2d2d",
    "file_handlers": [
        {
          "action": "./index.html",
          "accept": {
            "text/*": [".txt", ".js", ".json", ".html", ".css", ".lua", ".py", ".*", ""],
            "application/javascript": [".js"],
            "application/json": [".json"],
            "application/octet-stream": [".*", ""],
            "*/*": [".*", ""]
          }
        }
      ],
    "icons": [
    {
      "src": "icon.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}